// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id                   String      @id @default(cuid())
  reference            String      @unique
  designation          String
  categorie            String?
  unite                String?     @default("u")
  quantiteParBoite     Int         @default(1)
  stockMinimum         Int         @default(0)
  prixUnitaire         Float?      @default(0.0)
  codeBarre            String?     @unique
  referenceFournisseur String?   // Ex: REX-1234
  fournisseur          String?   // Ex: Rexel
  retourAttendu        Boolean     @default(false)
  
  // Computed via queries, but we can store initial stock
  stockInitial        Int         @default(0)
  
  mouvements          Mouvement[]
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model Chantier {
  id                  String      @id @default(cuid())
  nom                 String      @unique
  statut              String      @default("Actif") // Actif, Terminé
  
  mouvements          Mouvement[]
  outillages          Outillage[]
  mouvementsOutillage MouvementOutillage[]
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model Mouvement {
  id                  String      @id @default(cuid())
  date                DateTime    @default(now())
  type                String      // "Achat", "Depart", "Retour", "Consomme", "Perdu", "Correction"
  quantite            Int
  utilisateur         String?
  observation         String?
  
  articleId           String
  article             Article     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  chantierId          String?
  chantier            Chantier?   @relation(fields: [chantierId], references: [id], onDelete: Cascade)
  
  createdAt           DateTime    @default(now())
}

model Outillage {
  id            String    @id @default(cuid())
  nom           String    // ex: "Perforateur Hilti TE 6"
  marque        String?
  reference     String?   @unique // Numéro de série ou code-barres
  dateAchat     DateTime?
  valeur        Float?    @default(0.0)
  
  statut        String    @default("Disponible") // Disponible, En Chantier, En Réparation, Perdu
  chantierId    String?   
  chantier      Chantier? @relation(fields: [chantierId], references: [id])
  utilisateur   String?   // Qui a l'outil ?
  
  mouvements    MouvementOutillage[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model MouvementOutillage {
  id            String    @id @default(cuid())
  outillageId   String
  outillage     Outillage @relation(fields: [outillageId], references: [id], onDelete: Cascade)
  type          String    // "Emprunt", "Retour", "Réparation", "Perte"
  chantierId    String?
  chantier      Chantier? @relation(fields: [chantierId], references: [id])
  utilisateur   String
  date          DateTime  @default(now())
  observation   String?
}
